# Database
DATABASE_URL=postgresql+asyncpg://genesis:genesis_dev@localhost:5432/genesis_engine

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
# Leave SECRET_KEY unset (or use the placeholder below) and Genesis Engine
# will auto-generate a secure 256-bit key on first boot and write it back
# to .env automatically.  Set an explicit value here for production deploys.
# SECRET_KEY=           ← auto-generated if omitted / left as placeholder
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# World simulation
WORLD_TICK_INTERVAL_SECONDS=30

# Logging
LOG_LEVEL=INFO

# Admin
# Same auto-generation rule as SECRET_KEY — leave unset for first-boot
# auto-generation, or set explicitly for production.
# ADMIN_API_KEY=        ← auto-generated if omitted / left as placeholder
